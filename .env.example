DATABASE_URL=./data/console.db
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000

# Google Workspace SSO (production)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
WORKSPACE_DOMAIN=clovion.ai

# Magic-link fallback (default disabled per PRD §4.2)
AUTH_MAGIC_LINK_ENABLED=false
RESEND_API_KEY=

# Bootstrap staff users (seed-only) — comma-separated
SEED_STAFF_EMAILS=owner@clovion.ai
SEED_STAFF_PASSWORD=admin
